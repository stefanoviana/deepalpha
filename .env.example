# DeepAlpha Configuration
# Copy this file to .env and fill in your values

# ─── License Key (get yours at https://deepalphabot.com) ──────────────────
LICENSE_KEY=DA-XXXX-XXXX-XXXX-XXXX

# ─── Exchange: "bitget" (recommended), "hyperliquid", "binance", "bybit" ──
EXCHANGE=bitget

# ─── Bitget API Keys (create at https://www.bitget.com/account/newapi) ────
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSPHRASE=

# ─── Hyperliquid (if EXCHANGE=hyperliquid) ────────────────────────────────
PRIVATE_KEY=
WALLET_ADDRESS=

# ─── Binance Futures (if EXCHANGE=binance) ────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Bybit (if EXCHANGE=bybit) ───────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── Telegram Notifications (optional but recommended) ────────────────────
# Create a bot: https://t.me/BotFather -> /newbot
# Get your chat ID: https://t.me/userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Trading Settings (defaults work for most users) ──────────────────────
LEVERAGE=5
MAX_POSITIONS=3
