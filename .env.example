# Exchange (hyperliquid, binance, bybit)
EXCHANGE=hyperliquid

# Hyperliquid
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address

# Binance Futures (if EXCHANGE=binance)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Bybit (if EXCHANGE=bybit)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# Telegram notifications (optional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Trading config
LEVERAGE=5
MAX_POSITIONS=3
RISK_PER_TRADE=0.10
MAX_DAILY_LOSS_PCT=0.05
