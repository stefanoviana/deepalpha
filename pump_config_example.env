# ═══════════════════════════════════════════════════════════════════════════
# PUMP SCANNER CONFIGURATION
# Add these to your existing .env file
# ═══════════════════════════════════════════════════════════════════════════

# --- Detection thresholds ---
PUMP_SCAN_INTERVAL=3          # scan every 3 seconds
PUMP_VOL_SPIKE_MULT=5.0       # 5x normal volume = potential pump
PUMP_PRICE_SPIKE_PCT=0.03     # 3% price move in window
PUMP_PRICE_WINDOW=5           # 5 scan cycles window for price change
PUMP_EWMA_SPAN=20             # 20-period EWMA for volume baseline
PUMP_MIN_DOLLAR_VOL=500000    # ignore coins with < $500k volume

# --- Fakeout filters ---
PUMP_CONFIRM_CANDLES=3        # need 3 consecutive green candles
PUMP_MIN_RSI_ENTRY=60         # RSI must be > 60
PUMP_MAX_RSI_ENTRY=85         # RSI must be < 85
PUMP_MIN_BUY_RATIO=0.65      # 65%+ buy-side volume

# --- Position sizing ---
PUMP_LEVERAGE=5               # leverage for pump trades
PUMP_RISK_BUDGET_PCT=0.05     # 5% of equity for ALL pump trades
PUMP_MAX_POSITIONS=2          # max 2 pump trades at once

# --- Take profit / Stop loss ---
PUMP_SL_ATR_MULT=1.5          # SL = 1.5x ATR below entry
PUMP_TP1_PCT=0.05             # +5% -> close 40%
PUMP_TP2_PCT=0.10             # +10% -> close 30%, activate trailing
PUMP_TP3_PCT=0.20             # +20% -> close remaining
PUMP_TRAILING_PCT=0.03        # 3% trailing stop after TP2

# --- Dump short settings ---
PUMP_SHORT_RSI=80             # RSI > 80 for short entry
PUMP_SHORT_VOL_DECLINE=0.40   # 40% volume decline from peak
PUMP_SHORT_FUNDING=0.001      # funding > 0.1% = extreme
PUMP_SHORT_SL_ATR=2.0         # wider SL for shorts
PUMP_SHORT_TP_PCT=0.05        # 5% TP on short

# --- New listing detection ---
PUMP_LISTING_CHECK=30         # check every 30 seconds
PUMP_LISTING_DELAY=5          # wait 5s after detecting listing
PUMP_LISTING_RISK=0.02        # 2% equity per listing trade

# --- Cooldown ---
PUMP_COOLDOWN_SEC=1800        # 30 min cooldown per coin after trade
